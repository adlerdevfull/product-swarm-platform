APP_ENV=dev
APP_SECRET=change_me_product_swarm_secret_key_32
APP_DEBUG=1

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=product_db
DB_USER=product
DB_PASSWORD=product
DATABASE_URL=mysql://product:product@mysql:3306/product_db?serverVersion=8.0

REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=product_jwt_passphrase

# Hostname of this replica (set by Swarm service name / task slot)
APP_INSTANCE=app
